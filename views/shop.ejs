<%- include('partials/header', { title: 'Home | 3 Dogs and a Frog' }) %>
    <main>
        <div class="shop-container">
            <aside class="shop-filters">
                <h3>Categories</h3>
                <div class="filter-group">
                    <label><input type="checkbox" class="filter-cb category-cb" value="all" checked> All Gear</label>
                    <label><input type="checkbox" class="filter-cb category-cb" value="apparel"> Dog Apparel</label>
                    <label><input type="checkbox" class="filter-cb category-cb" value="camp"> Camp Gear</label>
                    <label><input type="checkbox" class="filter-cb category-cb" value="packs"> Packs & Carriers</label>
                </div>
                <h3>Size</h3>
                <div class="filter-group">
                    <label><input type="checkbox" class="filter-cb size-cb" value="small"> Small</label>
                    <label><input type="checkbox" class="filter-cb size-cb" value="medium"> Medium</label>
                    <label><input type="checkbox" class="filter-cb size-cb" value="large"> Large / XL</label>
                </div>
            </aside>

            <div class="shop-main">
                <h1 style="margin-top: 0; margin-bottom: 2rem; font-weight: 800; text-transform: uppercase; border-bottom: 2px solid #333; padding-bottom: 0.5rem;">Premium Pack Gear</h1>
                
                <div class="product-grid" id="shopProductGrid">
                    
                    <div class="product-card" data-id="1" data-name="Reflective Night Harness" data-price="45.99" data-image="/images/harness.jpg" data-category="apparel" data-size="medium">
                        <div class="product-image-container"><img src="/images/harness.jpg" alt="Reflective Night Harness" class="product-image"></div>
                        <div class="product-info">
                            <span class="category">Dog Apparel</span>
                            <h3>Reflective Night Harness</h3>
                            <p class="price">$45.99</p>
                            <button class="add-btn">Add to Bag</button>
                        </div>
                    </div>
                
                    <div class="product-card" data-id="2" data-name="Heavy-Duty Stainless Steel Basecamp Bowl" data-price="24.50" data-image="/images/bowl.jpg" data-category="camp" data-size="small">
                        <div class="product-image-container"><img src="/images/bowl.jpg" alt="Heavy-Duty Stainless Steel Basecamp Bowl" class="product-image"></div>
                        <div class="product-info">
                            <span class="category">Camp Gear</span>
                            <h3>Heavy-Duty Stainless Steel Basecamp Bowl</h3>
                            <p class="price">$24.50</p>
                            <button class="add-btn">Add to Bag</button>
                        </div>
                    </div>
                
                    <div class="product-card" data-id="3" data-name="High-Capacity Trail Backpack" data-price="65.00" data-image="/images/backpack.jpg" data-category="packs" data-size="large">
                        <div class="product-image-container">
                            <img src="/images/backpack.jpg" alt="High-Capacity Trail Backpack" class="product-image">
                            <div class="frog-approved-badge badge-overlay">
                                <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C12 2 5 10 5 15C5 18.866 8.134 22 12 22C15.866 22 19 18.866 19 15C19 10 12 2 12 2ZM12 20C9.238 20 7 17.761 7 15C7 11.5 11.2 4.8 12 3.6C12.8 4.8 17 11.5 17 15C17 17.761 14.762 20 12 20Z"/></svg>
                                <span>Frog-Tested Waterproof</span>
                            </div>
                        </div>
                        <div class="product-info">
                            <span class="category">Packs & Carriers</span>
                            <h3>High-Capacity Trail Backpack</h3>
                            <p class="price">$65.00</p>
                            <button class="add-btn">Add to Bag</button>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </main>
<%- include('partials/footer') %>
