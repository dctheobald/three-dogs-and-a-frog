<%- include('partials/header', { title: 'Home | 3 Dogs and a Frog' }) %>    
    <main>
        <section class="hero" style="width: 100%; height: 70vh; background-image: linear-gradient(rgba(0,0,0,0.1), rgba(0,0,0,0.4)), url('/images/hero.jpg'); background-size: cover; background-position: center; display: flex; align-items: center; justify-content: center; color: white; text-align: center; margin-bottom: 4rem;">
            <div style="max-width: 750px; padding: 2rem; text-shadow: 0 2px 4px rgba(0,0,0,0.5);">
                <h2 style="font-size: 3.8rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.05em; margin: 0 0 1.2rem 0; line-height: 1.1;">Adventure Awaits</h2>
                <p style="font-size: 1.3rem; font-weight: 500; margin: 0 0 2.5rem 0;">Luxury outdoor gear engineered for your loyal companion.</p>
                <a href="/shop" style="background-color: white; color: #333; text-decoration: none; padding: 1.2rem 2.5rem; font-size: 1.1rem; font-weight: 700; text-transform: uppercase;">Shop the Collection</a>
            </div>
        </section>

        <div style="max-width: 1400px; margin: 0 auto; padding: 0 2rem;">
            <div style="margin-bottom: 3rem; border-bottom: 2px solid #333; padding-bottom: 0.5rem;">
                <h2 style="margin: 0; font-size: 2rem; font-weight: 800; text-transform: uppercase;">Featured Gear</h2>
            </div>
            <div class="product-grid">
                
                <div class="product-card" data-id="1" data-name="Reflective Night Harness" data-price="45.99" data-image="/images/harness.jpg">
                    <div class="product-image-container"><img src="/images/harness.jpg" alt="Reflective Night Harness" class="product-image"></div>
                    <div class="product-info">
                        <span class="category">Dog Apparel</span>
                        <h3>Reflective Night Harness</h3>
                        <p class="price">$45.99</p>
                        <button class="add-btn">Add to Bag</button>
                    </div>
                </div>
            
                <div class="product-card" data-id="2" data-name="Heavy-Duty Stainless Steel Basecamp Bowl" data-price="24.50" data-image="/images/bowl.jpg">
                    <div class="product-image-container"><img src="/images/bowl.jpg" alt="Heavy-Duty Stainless Steel Basecamp Bowl" class="product-image"></div>
                    <div class="product-info">
                        <span class="category">Camp Gear</span>
                        <h3>Heavy-Duty Stainless Steel Basecamp Bowl</h3>
                        <p class="price">$24.50</p>
                        <button class="add-btn">Add to Bag</button>
                    </div>
                </div>
            
                <div class="product-card" data-id="3" data-name="High-Capacity Trail Backpack" data-price="65.00" data-image="/images/backpack.jpg">
                    <div class="product-image-container">
                        <img src="/images/backpack.jpg" alt="High-Capacity Trail Backpack" class="product-image">
                        <div class="frog-approved-badge badge-overlay">
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C12 2 5 10 5 15C5 18.866 8.134 22 12 22C15.866 22 19 18.866 19 15C19 10 12 2 12 2ZM12 20C9.238 20 7 17.761 7 15C7 11.5 11.2 4.8 12 3.6C12.8 4.8 17 11.5 17 15C17 17.761 14.762 20 12 20Z"/></svg>
                            <span>Frog-Tested Waterproof</span>
                        </div>
                    </div>
                    <div class="product-info">
                        <span class="category">Packs & Carriers</span>
                        <h3>High-Capacity Trail Backpack</h3>
                        <p class="price">$65.00</p>
                        <button class="add-btn">Add to Bag</button>
                    </div>
                </div>
            
            </div>
        </div>
    </main>

<%- include('partials/footer') %>
